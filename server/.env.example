# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Comma-separated allow-list for CORS (the SPA origin). First entry is primary.
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/edumentor
# For Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/edumentor?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────────
# JWT — use long random strings (e.g. `openssl rand -hex 48`)
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_with_a_long_random_string_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Days the refresh cookie lives (keep in sync with JWT_REFRESH_EXPIRES)
REFRESH_COOKIE_DAYS=7

# ─────────────────────────────────────────────────────────────
# Google Gemini (AI quizzes + tutor)  —  https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorised JS origins: http://localhost:5173 , http://localhost:5000
# Authorised redirect:   http://localhost:5000/api/auth/google/callback
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# Cloudinary (file uploads)  —  https://cloudinary.com/console
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=edumentor

# ─────────────────────────────────────────────────────────────
# Email (password reset) — optional in dev (links are logged to console)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="EduMentor AI <no-reply@edumentor.ai>"
